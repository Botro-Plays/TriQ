# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database (MySQL)
# For HidenCloud: encode @ in password as %40
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@localhost:3306/triq"

# Redis (for Socket.io adapter, rate limiting, session cache)
REDIS_URL="redis://localhost:6379"

# Firebase Admin SDK (download service account JSON and point to it)
FIREBASE_SERVICE_ACCOUNT_PATH="./config/firebase-service-account.json"
FIREBASE_PROJECT_ID="triq-digos"

# JWT (for custom token generation if needed)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# PayMongo (for platform tips)
PAYMONGO_SECRET_KEY="sk_test_xxx"
PAYMONGO_PUBLIC_KEY="pk_test_xxx"
PAYMONGO_WEBHOOK_SECRET="whsec_xxx"

# OSRM (Open Source Routing Machine)
OSRM_BASE_URL="http://localhost:5000" # or public OSRM instance

# FCM / Push Notifications (via Firebase Admin, configured above)
# No additional keys needed — Firebase Admin SDK handles FCM

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Frontend URL (for CORS)
WEB_APP_URL="https://triq.hidenplay.net"

# Logging
LOG_LEVEL="info"
